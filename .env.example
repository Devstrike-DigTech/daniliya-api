# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
# Get from Supabase project → Settings → Database → Connection string (Transaction mode)
DATABASE_URL=postgresql://postgres:[password]@[host]:6543/postgres?pgbouncer=true

# ── Redis ─────────────────────────────────────────────────────────────────────
# Get from Upstash → your Redis instance → REST API
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Encryption ────────────────────────────────────────────────────────────────
# AES-256 key for NIN/BVN/bank details — must be exactly 32 chars
ENCRYPTION_KEY=change-me-32-char-encryption-key!

# ── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key

# ── Flutterwave ───────────────────────────────────────────────────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your-key
FLUTTERWAVE_SECRET_HASH=your-webhook-secret-hash

# ── Smile ID (KYC) ────────────────────────────────────────────────────────────
SMILE_ID_PARTNER_ID=your-partner-id
SMILE_ID_API_KEY=your-api-key
SMILE_ID_ENVIRONMENT=sandbox  # sandbox | production

# ── SendGrid ─────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your-api-key
SENDGRID_FROM_EMAIL=noreply@daniliya.com
SENDGRID_FROM_NAME=Daniliya

# ── Termii (SMS/OTP) ──────────────────────────────────────────────────────────
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=Daniliya

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── AWS S3 (KYC documents) ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=eu-west-1
AWS_S3_KYC_BUCKET=daniliya-kyc-documents

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-dsn@sentry.io/your-project-id

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@daniliya.com
